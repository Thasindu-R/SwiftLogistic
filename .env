# ── SwiftTrack Environment Variables ──────────────────────────
# Override defaults from docker-compose.yml. Uncomment to customise.

# PostgreSQL
POSTGRES_DB=swifttrack
POSTGRES_USER=swifttrack
POSTGRES_PASSWORD=swifttrack

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# JWT Secret (change for production!)
JWT_SECRET=change_me_in_production

# Debug mode (true/false)
# DEBUG=true
